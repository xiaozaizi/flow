<?xml version="1.0" encoding="UTF-8"?>
<definitions id="sample-di" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             targetNamespace="http://www.flowable.org/processdef">
  <process id="sampleApproval" name="Sample Approval" isExecutable="true">
    <startEvent id="start" name="Start"/>
    <userTask id="approveTask" name="Approve"/>
    <endEvent id="end" name="End"/>
    <sequenceFlow id="flow1" sourceRef="start" targetRef="approveTask"/>
    <sequenceFlow id="flow2" sourceRef="approveTask" targetRef="end"/>
  </process>
</definitions>
